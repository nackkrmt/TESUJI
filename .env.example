# Public Supabase config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase key.
# Required for real atomic signup and direct server-side admin mutations.
# Use either one; do not expose this to the browser.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for hashing national ID/passport values before storing.
# Set a long random value per environment.
IDENTITY_HASH_SALT=

# Optional. Defaults to D:/Programming/Database.
GO_DATABASE_DIR=
SCHOOL_DATABASE_DIR=

# Optional. Set to supabase-js to disable CLI fallback for database imports.
SUPABASE_IMPORT_STRATEGY=
