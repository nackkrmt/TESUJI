# Public Supabase config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public base URL used for auth email redirects when an Origin header is unavailable.
NEXT_PUBLIC_SITE_URL=

# Server-only Supabase key.
# Required for real atomic signup and direct server-side admin mutations.
# Use either one; do not expose this to the browser.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for hashing national ID/passport values before storing.
# Set a long random value per environment.
IDENTITY_HASH_SALT=
